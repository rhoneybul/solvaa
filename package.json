{
  "name": "paddle",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:server & npm run dev:app",
    "dev:app": "npx expo start",
    "dev:web": "npx expo start --web",
    "dev:server": "npm --prefix server run dev",
    "test": "jest",
    "setup": "npm install && npm --prefix server install && cp -n server/.env.example server/.env 2>/dev/null; cp -n .env.example .env 2>/dev/null; echo '\\n✅ Setup done. Fill in server/.env and .env with your API keys.'"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/stack": "^7.8.6",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~55.0.8",
    "expo-location": "^55.1.4",
    "expo-network": "^55.0.9",
    "expo-sensors": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(expo-.*|@expo/.*|react-native.*|@react-native.*)/)"
    ]
  },
  "overrides": {
    "react-native-web": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0"
  }
}

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

# Project URL (looks like https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# anon/public key — safe to expose, used to verify JWTs from the app
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key — NEVER expose this in the app, server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optional APIs ─────────────────────────────────────────────────────────────
# Recreation.gov — free at https://ridb.recreation.gov
RIDB_API_KEY=

# ── Server config ─────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated origins allowed for CORS (leave * for local dev)
ALLOWED_ORIGINS=*

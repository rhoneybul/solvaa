# Copy this file to .env and fill in your keys
# Restart the dev server after editing

# Anthropic Claude API — required for AI trip planning
# Get free key at: https://console.anthropic.com
EXPO_PUBLIC_CLAUDE_API_KEY=sk-ant-your-key-here

# Strava — optional, auto-detects your kayaking skill level
# Create app at: https://www.strava.com/settings/api
EXPO_PUBLIC_STRAVA_CLIENT_ID=
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=

# Recreation.gov RIDB — optional, US campsite search
# Free key at: https://ridb.recreation.gov
EXPO_PUBLIC_RIDB_API_KEY=

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev: leave as http://localhost:3001
# Production: your Railway/Render URL e.g. https://paddle-api.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3001

# ── Supabase (app-side, public keys only) ─────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
